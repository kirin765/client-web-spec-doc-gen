{
  "name": "client-web-spec-doc-gen",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/generate-seo-assets.mjs",
    "dev": "vite",
    "dev:infra": "docker compose up -d",
    "dev:infra:down": "docker compose down",
    "dev:web": "node scripts/dev-web.mjs",
    "dev:web:e2e": "BACKEND_START_SCRIPT=start:e2e node scripts/dev-web.mjs",
    "dev:local": "npm run dev:infra && npm run dev:web",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:server": "npm --prefix server run test:unit",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:smoke": "node scripts/run-e2e.mjs --grep @smoke",
    "test:e2e:ui": "node scripts/run-e2e.mjs --ui",
    "e2e:api": "npm --prefix server run test:e2e",
    "e2e:web": "playwright test",
    "e2e:web:staging:setup": "playwright test -c playwright.staging.setup.config.ts --headed",
    "e2e:web:staging": "playwright test -c playwright.staging.config.ts",
    "e2e:web:google:setup": "playwright test -c playwright.google.setup.config.ts --headed",
    "e2e:web:google": "playwright test -c playwright.google.config.ts",
    "e2e:browsers": "playwright install chromium",
    "e2e": "npm run dev:infra && npm run e2e:api && npm run e2e:web",
    "prebuild": "node scripts/generate-seo-assets.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.4",
    "@react-pdf/renderer": "^4.3.0",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "i18next": "^25.1.3",
    "lucide-react": "^0.488.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.5.1",
    "react-router-dom": "^6.30.0",
    "tailwind-merge": "^3.2.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.0.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.0",
    "vitest": "^4.1.2"
  }
}
