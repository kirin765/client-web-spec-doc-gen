# =============================================================================
# 로컬 개발 환경 변수 예시
# =============================================================================
#
# 루트의 docker-compose.yml 기준 로컬 기본값:
# - Postgres: localhost:5432
# - Redis: localhost:6379
#
# server/.env.local 로 복사해서 사용하세요.
#
# 서버
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spec_gen_dev?schema=public

# Redis (캐시 + BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (최소 32자)
JWT_SECRET=your-secret-key-here-must-be-at-least-32-chars
JWT_EXPIRY=24h

# AWS S3 호환 스토리지 (PDF 저장)
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=spec-gen-documents

# 이메일 (매직링크, 알림)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# 프론트엔드 URL (CORS)
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:3001

# Google Login
GOOGLE_CLIENT_ID=

# 관리자 계정 (쉼표 구분 Gmail)
ADMIN_GOOGLE_EMAILS=admin@example.com
