{
  "name": "@spec-gen/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && nest build",
    "start": "node dist/server/src/main.js",
    "start:dev": "nest start --watch --entryFile server/src/main",
    "start:debug": "nest start --debug --watch --entryFile server/src/main",
    "start:prod": "npx prisma db execute --schema prisma/schema.prisma --file scripts/repair-failed-migrations.sql && npx prisma migrate deploy && node dist/server/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:e2e:server": "jest --config ./test/jest-e2e.json --runInBand",
    "test:e2e:reset": "prisma migrate reset --force --skip-generate --skip-seed",
    "test:e2e:seed": "ts-node scripts/seed-e2e.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@nestjs/bullmq": "^10.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "^5.0.0",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.10.1",
    "nodemailer": "^6.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "pdfkit": "^0.18.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^6.0.3",
    "jest": "^29.5.0",
    "prisma": "^5.0.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.0",
    "ts-node": "^10.9.0",
    "typescript": "~5.7.2"
  }
}
