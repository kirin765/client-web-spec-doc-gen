# =============================================================================
# 환경 변수 설정
# =============================================================================

# 서버
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spec_gen_dev?schema=public

# Redis (캐시 + BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-here
JWT_EXPIRY=24h

# S3 호환 스토리지 (PDF 저장)
AWS_S3_BUCKET=spec-gen-documents
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# 이메일 (매직링크, 알림)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@spec-gen.example.com

# 프론트엔드 URL (CORS)
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:3001

# Google Login
GOOGLE_CLIENT_ID=

# 관리자 계정 (쉼표 구분 Gmail)
ADMIN_GOOGLE_EMAILS=
