// Prisma 스키마 — 7개 모델 정의
// User, MagicLinkToken, ProjectRequest, RequirementDocument, Developer, MatchResult, PricingRuleVersion

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  role            Role      @default(CLIENT)
  name            String?
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  projectRequests  ProjectRequest[]
  developerProfile Developer?
  customerProfile  CustomerProfile?
  writtenReviews   Review[]

  @@map("users")
}

model MagicLinkToken {
  email     String   @unique
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("magic_link_tokens")
}

enum Role {
  CLIENT
  DEVELOPER
  ADMIN
}

model ProjectRequest {
  id              String               @id @default(cuid())
  userId          String?              @map("user_id")
  status          ProjectStatus        @default(DRAFT)
  projectName     String?              @map("project_name")
  siteType        String?              @map("site_type")
  contactMethod   String?              @map("contact_method")
  rawAnswers      Json?                @map("raw_answers")
  normalizedSpec  Json?                @map("normalized_spec")
  costEstimate    Json?                @map("cost_estimate")
  pricingVersion  String?              @map("pricing_version")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  submittedAt     DateTime?            @map("submitted_at")

  user            User?                @relation(fields: [userId], references: [id])
  documents       RequirementDocument[]
  matchResults    MatchResult[]
  proposals       Proposal[]
  quoteShares     QuoteShare[]

  @@index([userId])
  @@index([status])
  @@index([siteType])
  @@index([submittedAt])
  @@map("project_requests")
}

enum ProjectStatus {
  DRAFT
  SUBMITTED
  CALCULATING
  GENERATING_DOCUMENT
  MATCHING
  COMPLETED
  ARCHIVED
}

model RequirementDocument {
  id                String         @id @default(cuid())
  projectRequestId  String         @map("project_request_id")
  version           Int            @default(1)
  format            String         @default("json")
  storageUrl        String?        @map("storage_url")
  snapshotJson      Json           @map("snapshot_json")
  generatedAt       DateTime       @default(now()) @map("generated_at")

  projectRequest    ProjectRequest @relation(fields: [projectRequestId], references: [id], onDelete: Cascade)

  @@unique([projectRequestId, version, format])
  @@map("requirement_documents")
}

model Developer {
  id                          String             @id @default(cuid())
  userId                      String?            @unique @map("user_id")
  regionCode                  String?            @map("region_code")
  type                        DeveloperType      @default(FREELANCER)
  displayName                 String             @map("display_name")
  headline                    String             @default("")
  introduction                String?
  skills                      Json               @default("[]")
  specialties                 Json               @default("[]")
  supportedProjectTypes       Json               @default("[]") @map("supported_project_types")
  supportedCoreFeatures       Json               @default("[]") @map("supported_core_features")
  supportedEcommerceFeatures  Json               @default("[]") @map("supported_ecommerce_features")
  supportedDesignStyles       Json               @default("[]") @map("supported_design_styles")
  supportedDesignComplexities Json               @default("[]") @map("supported_design_complexities")
  supportedTimelines          Json               @default("[]") @map("supported_timelines")
  budgetMin                   Int                @default(0) @map("budget_min")
  budgetMax                   Int                @default(0) @map("budget_max")
  totalCareerYears            Int?               @map("total_career_years")
  availabilityStatus          AvailabilityStatus @default(AVAILABLE) @map("availability_status")
  avgResponseHours            Int                @default(24) @map("avg_response_hours")
  portfolioLinks              Json               @default("[]") @map("portfolio_links")
  regions                     Json               @default("[]")
  languages                   Json               @default("[]")
  active                      Boolean            @default(false)
  createdAt                   DateTime           @default(now()) @map("created_at")
  updatedAt                   DateTime           @updatedAt @map("updated_at")

  matchResults                MatchResult[]
  proposals                   Proposal[]
  quoteShares                 QuoteShare[]
  faqs                        ExpertFaq[]
  portfolios                  ExpertPortfolio[]
  reviews                     Review[]
  user                        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  region                      Region?            @relation("DeveloperRegion", fields: [regionCode], references: [code], onDelete: SetNull)

  @@index([active, availabilityStatus])
  @@index([budgetMin, budgetMax])
  @@index([totalCareerYears])
  @@index([regionCode])
  @@map("developers")
}

enum DeveloperType {
  FREELANCER
  AGENCY
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  LIMITED
}

model MatchResult {
  id                String         @id @default(cuid())
  projectRequestId  String         @map("project_request_id")
  developerId       String         @map("developer_id")
  score             Float
  reasons           Json           @default("[]")
  status            MatchStatus    @default(SUGGESTED)
  createdAt         DateTime       @default(now()) @map("created_at")

  projectRequest    ProjectRequest @relation(fields: [projectRequestId], references: [id], onDelete: Cascade)
  developer         Developer      @relation(fields: [developerId], references: [id])

  @@index([developerId])
  @@unique([projectRequestId, developerId])
  @@map("match_results")
}

enum MatchStatus {
  SUGGESTED
  CONTACTED
  ACCEPTED
  REJECTED
}

model Proposal {
  id                    String         @id @default(cuid())
  projectRequestId      String         @map("project_request_id")
  developerId           String         @map("developer_id")
  priceMin              Int            @map("price_min")
  priceMax              Int            @map("price_max")
  estimatedDurationText String         @map("estimated_duration_text")
  message               String
  portfolioLinks        Json           @default("[]") @map("portfolio_links")
  status                ProposalStatus @default(SUBMITTED)
  viewedAt              DateTime?      @map("viewed_at")
  decidedAt             DateTime?      @map("decided_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  projectRequest        ProjectRequest @relation(fields: [projectRequestId], references: [id], onDelete: Cascade)
  developer             Developer      @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@unique([projectRequestId, developerId])
  @@index([projectRequestId, status])
  @@index([developerId, status])
  @@map("proposals")
}

enum ProposalStatus {
  SUBMITTED
  VIEWED
  ACCEPTED
  REJECTED
}

model QuoteShare {
  id                String               @id @default(cuid())
  projectRequestId  String               @map("project_request_id")
  developerId       String               @map("developer_id")
  status            QuoteShareStatus     @default(SENT)
  startedAt         DateTime?            @map("started_at")
  completedAt       DateTime?            @map("completed_at")
  canceledAt        DateTime?            @map("canceled_at")
  canceledBy        QuoteShareCanceledBy? @map("canceled_by")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  projectRequest    ProjectRequest       @relation(fields: [projectRequestId], references: [id], onDelete: Cascade)
  developer         Developer            @relation(fields: [developerId], references: [id], onDelete: Cascade)
  review            Review?

  @@unique([projectRequestId, developerId])
  @@index([projectRequestId, status])
  @@index([developerId, status])
  @@map("quote_shares")
}

enum QuoteShareStatus {
  SENT
  IN_PROGRESS
  COMPLETED
  CANCELED_BY_USER
  CANCELED_BY_DEVELOPER
}

enum QuoteShareCanceledBy {
  USER
  DEVELOPER
}

model PricingRuleVersion {
  id            String   @id @default(cuid())
  version       String   @unique
  rules         Json
  effectiveFrom DateTime @map("effective_from")
  createdAt     DateTime @default(now()) @map("created_at")
  createdBy     String?  @map("created_by")

  @@index([effectiveFrom])
  @@map("pricing_rule_versions")
}

model CustomerProfile {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  displayName  String   @map("display_name")
  introduction String?
  regionCode   String?  @map("region_code")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  region       Region?  @relation("CustomerRegion", fields: [regionCode], references: [code], onDelete: SetNull)

  @@index([regionCode])
  @@map("customer_profiles")
}

model ExpertFaq {
  id         String   @id @default(cuid())
  developerId String  @map("developer_id")
  question   String
  answer     String
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  developer  Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@index([developerId, sortOrder])
  @@map("expert_faqs")
}

model ExpertPortfolio {
  id          String   @id @default(cuid())
  developerId String   @map("developer_id")
  description String
  imageUrls   Json     @default("[]") @map("image_urls")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  developer   Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@index([developerId, sortOrder])
  @@map("expert_portfolios")
}

model Review {
  id             String   @id @default(cuid())
  quoteShareId   String   @unique @map("quote_share_id")
  developerId    String   @map("developer_id")
  customerUserId String   @map("customer_user_id")
  rating         Int
  content        String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  quoteShare     QuoteShare @relation(fields: [quoteShareId], references: [id], onDelete: Cascade)
  developer      Developer  @relation(fields: [developerId], references: [id], onDelete: Cascade)
  customer       User       @relation(fields: [customerUserId], references: [id], onDelete: Cascade)

  @@index([developerId, createdAt])
  @@index([customerUserId])
  @@map("reviews")
}

model Region {
  code             String            @id
  name             String
  depth            Int
  parentCode       String?           @map("parent_code")
  sortOrder        Int               @default(0) @map("sort_order")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  parent           Region?           @relation("RegionHierarchy", fields: [parentCode], references: [code], onDelete: SetNull)
  children         Region[]          @relation("RegionHierarchy")
  customerProfiles CustomerProfile[] @relation("CustomerRegion")
  developers       Developer[]       @relation("DeveloperRegion")

  @@index([depth, sortOrder])
  @@index([parentCode, sortOrder])
  @@map("regions")
}
